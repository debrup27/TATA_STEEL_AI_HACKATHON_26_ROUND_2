# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=backend.settings.dev
DJANGO_SECRET_KEY=change-me-before-judging
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL + TimescaleDB) ─────────────────────────────────────
POSTGRES_DB=atal_db
POSTGRES_USER=atal_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── ChromaDB (embedded — no separate service) ────────────────────────────────
CHROMA_PERSIST_DIR=/chroma_data

# ── Ollama (self-hosted Qwen3.5:9b — OpenAI-compatible /v1 endpoint) ─────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:9b
SKIP_OLLAMA_WAIT=0

# ── Model weight paths (volume-mounted; fall back to HF hub ID if unset) ─────
BGE_M3_MODEL_PATH=/models/bge-m3
BGE_RERANKER_MODEL_PATH=/models/bge-reranker-v2-m3

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SIGNING_KEY=change-me-jwt-signing-key

# ── CORS (comma-separated origins for local dev) ─────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
