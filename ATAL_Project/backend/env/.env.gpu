# GPU production profile — copy to .env before running: docker compose up atal -d
SKIP_OLLAMA_WAIT=0
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_SMALL_MODEL=qwen3.5:0.8b
OLLAMA_KEEP_ALIVE=-1
EMBEDDING_DEVICE=cuda
RAG_USE_RERANKER=0
INGEST_CORPUS_ON_START=0
CORPUS_DIR=/app/data/corpus
